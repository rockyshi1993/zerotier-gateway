{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "local-mixed",
      "listen": "127.0.0.1",
      "listen_port": ${LOCAL_PROXY_PORT}
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "socks",
      "tag": "ubuntu-proxy",
      "server": "${PROXY_CONNECT_HOST}",
      "server_port": ${PROXY_PORT}${CLIENT_PROXY_AUTH_JSON}
    }
  ],
  "route": {
    "rules": ${ROUTE_RULES_JSON},
    "final": "ubuntu-proxy"
  }
}
