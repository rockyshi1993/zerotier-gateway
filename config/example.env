UBUNTU_ZT_IP=10.246.77.1
HOME_PC_ZT_IP=10.246.77.10
WORK_PC_ZT_IP=10.246.77.20

PROXY_BIND_IP=10.246.77.1
PROXY_PORT=10808
PROXY_USERNAME=
PROXY_PASSWORD=

PROXY_MODE=manual
PROXY_DEFAULT=proxy
DIRECT_DOMAINS=localhost,*.local
DIRECT_DOMAIN_SUFFIXES=.local
